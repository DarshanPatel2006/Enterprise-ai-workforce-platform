# ============================================================
# Enterprise AI Workforce Management Platform - .gitignore
# ============================================================

# --- SECURITY: NEVER UPLOAD THESE ---
.env
*.env
.env.*
backend/.env

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
pip-log.txt

# --- Virtual Environments ---
venv/
env/
.venv/
tools/python/

# --- Database Files (local data) ---
*.db
*.sqlite
*.sqlite3
workforce.db

# --- ChromaDB Vector Store (local index) ---
tools/chroma_db/

# --- Uploads (employee photos etc) ---
backend/uploads/

# --- Node Modules ---
node_modules/
frontend/node_modules/

# --- Frontend Build ---
frontend/dist/
frontend/build/

# --- Logs ---
*.log
logs/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Test Cache ---
.pytest_cache/
.coverage
htmlcov/

# --- OS Files ---
desktop.ini
